{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/(site)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(site)/layout.js"
    ],
    "/(site)/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(site)/loading.js"
    ],
    "/(site)/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(site)/not-found.js"
    ],
    "/(site)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(site)/page.js"
    ],
    "/api/auth/[...nextauth]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/auth/[...nextauth]/route.js"
    ],
    "/dashboard/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/dashboard/layout.js"
    ],
    "/dashboard/articles/new/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/dashboard/articles/new/page.js"
    ],
    "/api/admin/ai/generate/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/admin/ai/generate/route.js"
    ],
    "/dashboard/articles/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/dashboard/articles/page.js"
    ],
    "/(site)/posts/[slug]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(site)/posts/[slug]/page.js"
    ],
    "/dashboard/articles/[slug]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/dashboard/articles/[slug]/page.js"
    ],
    "/dashboard/users/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/dashboard/users/page.js"
    ],
    "/_not-found/page": [
      "static/chunks/webpack.js",
