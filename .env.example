# MongoDB connection string for the MongoDB Atlas cluster
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/neuracms?retryWrites=true&w=majority

# Только для `next build` без доступа к БД (CI). Не включайте в .env для `next dev` / production —
# иначе панель /dashboard будет пустой, а записи в Mongo всё равно создаются.
# SKIP_DB_DURING_BUILD=1

# Auth.js / NextAuth secret
NEXTAUTH_SECRET=your-super-secure-secret
NEXTAUTH_URL=http://localhost:3000

# OpenAI API key for Grok
OPENAI_API_KEY=your-openai-api-key
GROK_MODEL=grok-1

# Unsplash API access key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
